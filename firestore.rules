rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function currentUserPath() {
      return /databases/$(database)/documents/usuarios/$(request.auth.uid);
    }

    function currentUserData() {
      return get(currentUserPath()).data;
    }

    function isAdmin() {
      return isAuthenticated() && currentUserData().rol == "ADMIN";
    }

    function isTechnician() {
      return isAuthenticated() && currentUserData().rol == "TECHNICIAN";
    }

    function isSelf(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function keepsProtectedUserFields() {
      return request.resource.data.idUsuario == resource.data.idUsuario
        && request.resource.data.correo == resource.data.correo
        && request.resource.data.rol == resource.data.rol
        && request.resource.data.estado == resource.data.estado
        && request.resource.data.fechaCreacion == resource.data.fechaCreacion
        && request.resource.data.zonaAsignada == resource.data.zonaAsignada;
    }

    match /usuarios/{userId} {
      allow read: if isSelf(userId) || isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin() || (isSelf(userId) && keepsProtectedUserFields());
      allow delete: if false;
    }

    match /clients/{clientId} {
      allow read: if isAdmin() || isTechnician();
      allow create, update: if isAdmin() || isTechnician();
      allow delete: if false;
    }

    match /events/{eventId} {
      allow read: if isAdmin() || isTechnician();
      allow create, update: if isAdmin() || isTechnician();
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
